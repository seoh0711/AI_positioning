# Environment Variables for AI Job Positioner

# Gemini API Key (Required)
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth (Required for Authentication)
# Obtain from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth Configuration
# For production, set to your deployment URL (e.g., https://your-app.vercel.app)
# For local dev, use http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# A secret string used to encrypt cookies (Required for production)
# You can generate a random string using: openssl rand -base64 32
NEXTAUTH_SECRET=your_random_secret_here
